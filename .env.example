# freestanding Neon / Supabase / Render Postgres connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

AUTH_SECRET="generate-with: openssl rand -base64 32"
BOOPS_INTERNAL_SECRET="same-as-AUTH_SECRET-is-fine"

# --- Local ---
# AUTH_URL="http://localhost:3000"
# CLIENT_URL="http://localhost:3000"
# NEXT_PUBLIC_SERVER_URL="http://localhost:3001"

# --- Production ---
# Vercel: https://boopsinurface.vercel.app
# Render: https://boops.onrender.com
# Full paste files: env/production.vercel.env, env/production.render.env

AUTH_URL="https://boopsinurface.vercel.app"
CLIENT_URL="https://boopsinurface.vercel.app"
NEXT_PUBLIC_SERVER_URL="https://boops.onrender.com"

# Google OAuth — https://boopsinurface.vercel.app/api/auth/callback/google
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://boopsinurface.vercel.app/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
