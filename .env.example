# freestanding Neon / Supabase / Render Postgres connection string
# Example (Neon): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

AUTH_SECRET="generate-with: openssl rand -base64 32"
BOOPS_INTERNAL_SECRET="same-as-AUTH_SECRET-is-fine"

# --- Local ---
# AUTH_URL="http://localhost:3000"
# CLIENT_URL="http://localhost:3000"
# NEXT_PUBLIC_SERVER_URL="http://localhost:3001"

# --- Production (fill after deploy) ---
AUTH_URL="https://YOUR-APP.vercel.app"
CLIENT_URL="https://YOUR-APP.vercel.app"
NEXT_PUBLIC_SERVER_URL="https://YOUR-SERVER.onrender.com"

# Google OAuth
# Redirect URI: https://YOUR-APP.vercel.app/api/auth/callback/google
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# Callback: https://YOUR-APP.vercel.app/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
